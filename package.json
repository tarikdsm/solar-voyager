{
  "name": "solar-voyager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:tools": "python -m unittest discover -s tools/tests -p \"test_*.py\" -v",
    "lint": "eslint .",
    "typecheck": "tsc -b tsconfig.node.json --pretty false && tsc --noEmit --project tsconfig.json",
    "format:check": "prettier --check .",
    "check:tasks": "node tools/checks/taskSchema.mjs",
    "check:budgets": "node tools/checks/assetBudgets.mjs",
    "bench:scaffold": "node tools/bench/scaffoldBench.mjs",
    "golden:regen": "node tools/generateGoldenTrajectories.mjs"
  },
  "dependencies": {
    "@preact/signals": "^2.9.4",
    "preact": "^10.29.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^22.20.1",
    "@types/three": "^0.185.1",
    "ajv": "^8.20.0",
    "eslint": "^9.39.5",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
